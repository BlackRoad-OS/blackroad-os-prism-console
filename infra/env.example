# Example Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit .env files with real credentials

# Application
NODE_ENV=development
PORT=3000

# Database (example - update with your actual database)
# DATABASE_URL=postgresql://user:password@localhost:5432/prism_console

# API Keys (example - add your services)
# API_KEY=your-api-key-here

# Railway Configuration (example)
# RAILWAY_ENVIRONMENT=production

# Cloudflare Configuration (example)
# CLOUDFLARE_API_TOKEN=your-token-here
# CLOUDFLARE_ZONE_ID=your-zone-id
