NEXT_PUBLIC_ENV=dev
NEXT_PUBLIC_BEACON_URL=https://placeholder-beacon
NEXT_PUBLIC_CORE_HUB=wss://placeholder-core-hub
NEXT_PUBLIC_API_BASE_URL=https://api-placeholder

# ==========================================
# Stripe Configuration
# ==========================================
# NEVER commit real Stripe keys! Set these in your deployment provider's secrets manager.
# Test keys start with sk_test_ / pk_test_; live keys start with sk_live_ / pk_live_.

STRIPE_SECRET_KEY=
# Server-side Stripe secret key (sk_test_... or sk_live_...)

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Client-side Stripe publishable key (pk_test_... or pk_live_...)

STRIPE_WEBHOOK_SECRET=
# Stripe webhook signing secret (whsec_...)

# Stripe Price IDs – set after creating products in the Stripe Dashboard
STRIPE_PRICE_PRISM_BASIC=
STRIPE_PRICE_PRISM_PRO=
STRIPE_PRICE_PRISM_ENTERPRISE=
STRIPE_PRICE_PLATFORM_STARTER=
STRIPE_PRICE_PLATFORM_GROWTH=
STRIPE_PRICE_PLATFORM_SCALE=
STRIPE_PRICE_DRIVE_100GB=
STRIPE_PRICE_DRIVE_1TB=
STRIPE_PRICE_DRIVE_10TB=
STRIPE_PRICE_OPERATOR_SEAT=
STRIPE_PRICE_AGENT_PACK_10=
